{
  "name": "stubfetch",
  "version": "0.1.0",
  "description": "Deterministic fake APIs and DB for AI agent tests",
  "keywords": [
    "ai",
    "agents",
    "testing",
    "mock",
    "http",
    "fetch",
    "github",
    "stripe",
    "openai",
    "anthropic",
    "deterministic",
    "e2e",
    "integration-testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vgulerianb/stubfetch.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "docs", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
